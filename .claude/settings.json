{
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "node .claude/hooks/guard-bash.cjs" }] },
      { "matcher": "Edit|Write", "hooks": [{ "type": "command", "command": "node .claude/hooks/guard-process.cjs" }] },
      { "matcher": "AskUserQuestion", "hooks": [{ "type": "command", "command": "node .claude/hooks/guard-ask.cjs" }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "hooks": [{ "type": "command", "command": "node .claude/hooks/post-edit-lint.cjs" }] }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "node .claude/hooks/stop-complete.cjs" }] }
    ]
  }
}
